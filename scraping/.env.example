# EightFold Lead Generation — API Keys
# Copy to .env and fill in your keys

# UK Companies House — free, get key at https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=

# Google PageSpeed Insights — free, get key at https://console.cloud.google.com/
GOOGLE_API_KEY=

# Facebook Ad Library API — free, create app at https://developers.facebook.com/
FACEBOOK_APP_TOKEN=

# Proxy (optional, needed for CN site access)
PROXY_URL=
